# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/auction-app

# JWT — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-change-in-production

# CORS / Socket origin (set to your deployed frontend URL in production)
CLIENT_URL=http://localhost:5173

# Gemini AI — get a free key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# Cloudinary — optional; if set, images are stored in Cloudinary instead of local disk
# Get credentials at https://cloudinary.com (free tier available)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
